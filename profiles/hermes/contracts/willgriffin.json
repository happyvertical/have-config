{
  "schema": "https://happyvertical.com/hermes-agent-contract/v1",
  "slug": "willgriffin",
  "kind": "project-hermes",
  "identity": {
    "display_name": "willgriffin",
    "email": "willgriffin@happyvertical.com",
    "idp_account": "willgriffin"
  },
  "role": {
    "project_leader": true,
    "primary_repo": "willgriffin/willgriffin.dev",
    "related_repos": [
      "happyvertical/iac",
      "happyvertical/have-config"
    ],
    "orientation": [
      "Start with the site repository README, deployment manifests, and current production state before changing behavior.",
      "Treat site maintenance, CI, deploy verification, analytics review, and storage-backed asset workflows as the default role.",
      "Use iac for deployed resources and have-config for shared agent runtime policy."
    ]
  },
  "project_lead": {
    "vikunja": {
      "url": "https://todo.happyvertical.com",
      "project": "Willgriffin",
      "board": "Development",
      "buckets": [
        "Inbox",
        "Ready",
        "In Progress",
        "Review",
        "Blocked",
        "Done"
      ],
      "labels": [
        "bug",
        "feature",
        "ops",
        "ci",
        "deploy",
        "secrets",
        "analytics",
        "storage",
        "blocked"
      ],
      "done_criteria": [
        "The relevant PR is merged or the accepted non-code outcome is documented.",
        "Required tests or checks have passed or the task explains why they were skipped.",
        "The deployed surface has been verified when the task affects production.",
        "Vikunja has final status, PR/deploy links, and any follow-up work."
      ]
    },
    "delegation": {
      "use_subagents_for": [
        "large-development",
        "ci-debugging",
        "deploy-monitoring",
        "cross-repo-work",
        "long-running-investigation"
      ],
      "worker_record_required": true
    }
  },
  "board": {
    "enabled": true,
    "project": "happyvertical/7",
    "label": "willgriffin"
  },
  "permissions": {
    "github": {
      "willgriffin/willgriffin.dev": "maintain",
      "happyvertical/iac": "pull-request",
      "happyvertical/have-config": "read"
    },
    "kubernetes": {
      "service_account": "hermes/hermes-willgriffin",
      "namespaces": [
        "willgriffin",
        "hermes"
      ],
      "rbac_profile": "project-maintainer"
    },
    "sops_profiles": [
      "willgriffin"
    ],
    "warden_paths": [
      "hermes/willgriffin/*"
    ]
  },
  "services": {
    "idp": "required",
    "email": "required",
    "zulip": "required",
    "vikunja": "required",
    "warden": "required",
    "contextforge": "required",
    "hindsight": "required",
    "bifrost": "required",
    "oxicloud": "required",
    "analytics": "required",
    "storage": "required",
    "telegram": "disabled"
  },
  "service_access": {
    "bifrost": {
      "policy": "required",
      "providers": [
        "bifrost"
      ],
      "credential_source": "sops",
      "runtime_env": [
        "HERMES_BIFROST_BASE_URL",
        "HERMES_BIFROST_API_KEY"
      ],
      "notes": [
        "Fallback model access uses hermes_willgriffin_virtual_key from the hermes-bifrost-keys Secret."
      ]
    },
    "oxicloud": {
      "policy": "required",
      "account": "kanidm-sso",
      "providers": [
        "oxicloud"
      ],
      "credential_source": "warden-or-sops",
      "runtime_env": [
        "OXICLOUD_URL"
      ],
      "warden_paths": [
        "hermes/willgriffin/oxicloud"
      ],
      "notes": [
        "OxiCloud login is IDP-backed. Add a WebDAV or app-token provider hook before requiring rclone credentials in runtime."
      ]
    },
    "analytics": {
      "policy": "required",
      "providers": [
        "matomo",
        "plausible"
      ],
      "credential_source": "sops",
      "runtime_env": [
        "MATOMO_URL",
        "MATOMO_AUTH_TOKEN",
        "PLAUSIBLE_URL"
      ],
      "secret_env": [
        "MATOMO_AUTH_TOKEN"
      ],
      "warden_paths": [
        "hermes/willgriffin/analytics"
      ]
    },
    "storage": {
      "policy": "required",
      "providers": [
        "garage-s3"
      ],
      "credential_source": "sops",
      "runtime_env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_DEFAULT_REGION",
        "AWS_ENDPOINT_URL_S3"
      ],
      "optional_runtime_env": [
        "AWS_REGION",
        "AWS_PROFILE",
        "GARAGE_S3_ENDPOINT"
      ],
      "secret_env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY"
      ],
      "warden_paths": [
        "hermes/willgriffin/storage"
      ],
      "buckets": [
        "hermes-willgriffin"
      ]
    }
  },
  "runtime": {
    "hindsight_bank": "willgriffin-hermes",
    "check_setup_required": true,
    "have_config_drift_policy": "report-and-sync"
  }
}
