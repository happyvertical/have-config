{
  "schema": "https://happyvertical.com/hermes-agent-contract/v1",
  "slug": "magnateos",
  "kind": "project-hermes",
  "identity": {
    "display_name": "magnateos",
    "email": "magnateos@happyvertical.com",
    "idp_account": "magnateos"
  },
  "role": {
    "project_leader": true,
    "primary_repo": "happyvertical/magnateos.com",
    "related_repos": [
      "happyvertical/iac",
      "happyvertical/have-config"
    ],
    "orientation": [
      "Start in the primary repo README, AGENTS or CLAUDE instructions, docs/adr, and deploy manifests before changing behavior.",
      "Treat project maintenance, issue triage, CI, deploy verification, and small product development as the default role.",
      "Use iac for deployed resources and have-config for shared agent runtime policy."
    ]
  },
  "project_lead": {
    "vikunja": {
      "url": "https://todo.happyvertical.com",
      "project": "Magnateos",
      "board": "Development",
      "buckets": [
        "Inbox",
        "Ready",
        "In Progress",
        "Review",
        "Blocked",
        "Done"
      ],
      "labels": [
        "bug",
        "feature",
        "ops",
        "ci",
        "deploy",
        "secrets",
        "blocked"
      ],
      "done_criteria": [
        "The relevant PR is merged or the accepted non-code outcome is documented.",
        "Required tests or checks have passed or the task explains why they were skipped.",
        "The deployed surface has been verified when the task affects production or staging.",
        "Vikunja has final status, PR/deploy links, and any follow-up work."
      ]
    },
    "delegation": {
      "use_subagents_for": [
        "large-development",
        "ci-debugging",
        "deploy-monitoring",
        "cross-repo-work",
        "long-running-investigation"
      ],
      "worker_record_required": true
    }
  },
  "permissions": {
    "github": {
      "happyvertical/magnateos.com": "maintain",
      "happyvertical/iac": "pull-request",
      "happyvertical/have-config": "read"
    },
    "kubernetes": {
      "service_account": "hermes/hermes-magnateos",
      "namespaces": [
        "magnateos-production",
        "magnateos-staging",
        "magnateos-dev",
        "hermes"
      ],
      "rbac_profile": "project-maintainer"
    },
    "sops_profiles": [
      "magnateos"
    ],
    "warden_paths": [
      "hermes/magnateos/*"
    ]
  },
  "services": {
    "idp": "required",
    "email": "required",
    "zulip": "required",
    "vikunja": "required",
    "warden": "required",
    "contextforge": "required",
    "hindsight": "required",
    "bifrost": "required",
    "oxicloud": "required",
    "analytics": "required",
    "storage": "required",
    "telegram": "pending-human-token"
  },
  "service_access": {
    "bifrost": {
      "policy": "required",
      "providers": [
        "bifrost"
      ],
      "credential_source": "sops",
      "runtime_env": [
        "HERMES_BIFROST_BASE_URL",
        "HERMES_BIFROST_API_KEY"
      ],
      "notes": [
        "Fallback model access uses hermes_magnateos_virtual_key from the hermes-bifrost-keys Secret."
      ]
    },
    "oxicloud": {
      "policy": "required",
      "account": "kanidm-sso",
      "providers": [
        "oxicloud"
      ],
      "credential_source": "warden-or-sops",
      "runtime_env": [
        "OXICLOUD_URL"
      ],
      "warden_paths": [
        "hermes/magnateos/oxicloud"
      ],
      "notes": [
        "OxiCloud login is IDP-backed. Add a WebDAV or app-token provider hook before requiring rclone credentials in runtime."
      ]
    },
    "analytics": {
      "policy": "required",
      "providers": [
        "matomo",
        "plausible"
      ],
      "credential_source": "sops",
      "runtime_env": [
        "MATOMO_URL",
        "MATOMO_AUTH_TOKEN",
        "PLAUSIBLE_URL"
      ],
      "secret_env": [
        "MATOMO_AUTH_TOKEN"
      ],
      "warden_paths": [
        "hermes/magnateos/analytics"
      ]
    },
    "storage": {
      "policy": "required",
      "providers": [
        "garage-s3"
      ],
      "credential_source": "sops",
      "runtime_env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_DEFAULT_REGION",
        "AWS_ENDPOINT_URL_S3"
      ],
      "optional_runtime_env": [
        "AWS_REGION",
        "AWS_PROFILE",
        "GARAGE_S3_ENDPOINT"
      ],
      "secret_env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY"
      ],
      "warden_paths": [
        "hermes/magnateos/storage"
      ],
      "buckets": [
        "hermes-magnateos"
      ]
    }
  },
  "runtime": {
    "hindsight_bank": "magnateos-hermes",
    "check_setup_required": true,
    "have_config_drift_policy": "report-and-sync"
  }
}
