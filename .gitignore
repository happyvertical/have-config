.DS_Store
*.swp
*.swo
node_modules/

# Copilot CLI session transcripts can leak into the working dir if
# probe prompts reference filenames (see README — review outputs
# should go to /tmp, not the repo). Narrow patterns instead of `*.jsonl`
# so we don't accidentally ignore legitimate fixtures or test data.
*-test.jsonl
.copilot-session-*.jsonl
copilot-session-*.jsonl
