.DS_Store
*.swp
*.swo
node_modules/

# Copilot CLI session transcripts can leak into the working dir if
# probe prompts reference filenames. Narrow to the specific transcript
# prefix copilot uses; don't ignore generic `*-test.jsonl` patterns
# that could match legitimate fixtures (e.g. `fixtures/payment-test.jsonl`).
# The real rule lives in the review-cycle docs: review outputs go to
# /tmp, not the repo.
.copilot-session-*.jsonl
copilot-session-*.jsonl
